{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "js_src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },

  "include": ["src/**/*.ts"],

  "references": [
    { "path": "../shared" }
  ]
}
